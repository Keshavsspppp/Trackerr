# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example committed as a template
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# do NOT ignore .env.example — it is the public template
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kiro spec internals (optional — remove if you want specs in the repo)
.kiro/

# editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# markdown files - ignore all except README.md and CONTRIBUTING.md
*.md
!README.md
!CONTRIBUTING.md
